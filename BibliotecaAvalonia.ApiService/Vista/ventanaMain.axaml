<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="using:BibliotecaAvalonia.Controlador"
        x:Class="BibliotecaAvalonia.Vista.ventanaMain"
        x:DataType="ctrl:controlador_biblioteca"
        Title="Gestión de Biblioteca" Width="900" Height="700"
        Background="#F5F5F5">

    <Grid ColumnDefinitions="320,*" RowDefinitions="Auto,*,Auto">

        <!-- ============================================================
             COLUMNA IZQUIERDA – Formulario de entrada
             ============================================================ -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                Background="White" Padding="16" Margin="8"
                CornerRadius="8" BoxShadow="0 2 8 0 #22000000">

            <ScrollViewer>
                <StackPanel Spacing="10">

                    <!-- Título de la sección -->
                    <TextBlock Text="➕ Nuevo artículo"
                               FontSize="16" FontWeight="Bold" Foreground="#333"/>

                    <!-- Campos comunes -->
                    <TextBlock Text="Título *" FontSize="12" Foreground="#666"/>
                    <TextBox Text="{Binding TxtTitulo}" Watermark="Título del artículo..."/>

                    <TextBlock Text="Año (1500 – actual) *" FontSize="12" Foreground="#666"/>
                    <TextBox Text="{Binding TxtAnio}" Watermark="Ej: 2023"/>

                    <!-- Campos solo para Libro -->
                    <Border Background="#EEF6FF" CornerRadius="6" Padding="10">
                        <StackPanel Spacing="6">
                            <TextBlock Text="📖 Campos de Libro" FontWeight="SemiBold" Foreground="#1565C0"/>
                            <TextBlock Text="ISBN-10 *" FontSize="12" Foreground="#666"/>
                            <TextBox Text="{Binding TxtIsbn}" Watermark="10 dígitos (ej: 0747532699)"/>
                            <Button Content="➕ Añadir Libro"
                                    Command="{Binding AgregarLibroCommand}"
                                    HorizontalAlignment="Stretch"
                                    Background="#1565C0" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- Campos solo para Audiolibro -->
                    <Border Background="#F3FBF3" CornerRadius="6" Padding="10">
                        <StackPanel Spacing="6">
                            <TextBlock Text="🎧 Campos de Audiolibro" FontWeight="SemiBold" Foreground="#2E7D32"/>
                            <TextBlock Text="Fecha inicio disponibilidad" FontSize="12" Foreground="#666"/>
                            <TextBox Text="{Binding TxtFechaInicio}" Watermark="yyyy-MM-dd"/>
                            <TextBlock Text="Fecha fin disponibilidad" FontSize="12" Foreground="#666"/>
                            <TextBox Text="{Binding TxtFechaFin}" Watermark="yyyy-MM-dd"/>
                            <Button Content="➕ Añadir Audiolibro"
                                    Command="{Binding AgregarAudiolibroCommand}"
                                    HorizontalAlignment="Stretch"
                                    Background="#2E7D32" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Separator Margin="0,4"/>

                    <!-- Acciones sobre el elemento seleccionado -->
                    <TextBlock Text="✏️ Artículo seleccionado" FontSize="14" FontWeight="Bold" Foreground="#333"/>

                    <Button Content="💾 Guardar cambios (editar)"
                            Command="{Binding EditarCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#F57C00" Foreground="White"/>

                    <Button Content="🗑️ Eliminar seleccionado"
                            Command="{Binding EliminarCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#C62828" Foreground="White"/>

                    <Button Content="📚 Cambiar estado préstamo"
                            Command="{Binding CambiarEstadoPrestamoCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#6A1B9A" Foreground="White"/>

                    <Separator Margin="0,4"/>

                    <!-- Valoraciones -->
                    <TextBlock Text="⭐ Añadir valoración" FontSize="14" FontWeight="Bold" Foreground="#333"/>

                    <TextBlock Text="Nota (0-10) *" FontSize="12" Foreground="#666"/>
                    <TextBox Text="{Binding TxtNota}" Watermark="0 – 10"/>

                    <TextBlock Text="Usuario *" FontSize="12" Foreground="#666"/>
                    <TextBox Text="{Binding TxtUsuarioId}" Watermark="ID del usuario"/>

                    <TextBlock Text="Comentario (opcional)" FontSize="12" Foreground="#666"/>
                    <TextBox Text="{Binding TxtComentario}" Watermark="Comentario..." Height="60"
                             AcceptsReturn="True" TextWrapping="Wrap"/>

                    <Button Content="⭐ Añadir valoración"
                            Command="{Binding AnadirValoracionCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#F9A825" Foreground="White"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ============================================================
             COLUMNA DERECHA – FILA 0: Barra de búsqueda y acciones globales
             ============================================================ -->
        <Border Grid.Column="1" Grid.Row="0"
                Background="White" Padding="12" Margin="0,8,8,4"
                CornerRadius="8" BoxShadow="0 2 8 0 #22000000">
            <StackPanel Spacing="8">

                <TextBlock Text="🔍 Buscar y filtrar" FontSize="14" FontWeight="Bold" Foreground="#333"/>

                <Grid ColumnDefinitions="*,Auto,120,Auto,Auto">
                    <TextBox Grid.Column="0" Text="{Binding TxtBusqueda}"
                             Watermark="Buscar por título..." Margin="0,0,4,0"/>

                    <ComboBox Grid.Column="2" SelectedItem="{Binding FiltroTipo}"
                              PlaceholderText="Tipo..." Margin="0,0,4,0">
                        <ComboBoxItem Content=""/>
                        <ComboBoxItem Content="Libro"/>
                        <ComboBoxItem Content="Audiolibro"/>
                    </ComboBox>

                    <Button Grid.Column="3" Content="Buscar"
                            Command="{Binding BuscarCommand}"
                            Background="#1565C0" Foreground="White" Margin="0,0,4,0"/>

                    <Button Grid.Column="4" Content="✖ Limpiar"
                            Command="{Binding LimpiarBusquedaCommand}"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="📤 Exportar CSV"
                            Command="{Binding ExportarCommand}"
                            Background="#00695C" Foreground="White"/>
                    <Button Content="📥 Importar CSV"
                            Command="{Binding ImportarCommand}"
                            Background="#37474F" Foreground="White"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ============================================================
             COLUMNA DERECHA – FILA 1: Lista de artículos
             ============================================================ -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="White" Padding="12" Margin="0,4,8,4"
                CornerRadius="8" BoxShadow="0 2 8 0 #22000000">

            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0" Text="📋 Catálogo"
                           FontSize="14" FontWeight="Bold" Foreground="#333" Margin="0,0,0,8"/>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding ListaFiltrada}"
                         SelectedItem="{Binding ArticuloSeleccionado}"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" CornerRadius="4" Margin="0,2"
                                    Background="#FAFAFA">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Titulo}" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Anio}" FontSize="11" Foreground="#777"/>
                                        <TextBlock Text="{Binding FechaAdquisicion, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                   FontSize="11" Foreground="#aaa"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ============================================================
             COLUMNA DERECHA – FILA 2: Barra de estado
             ============================================================ -->
        <Border Grid.Column="1" Grid.Row="2"
                Background="#E8F5E9" Padding="10,6" Margin="0,4,8,8"
                CornerRadius="6">
            <TextBlock Text="{Binding MensajeEstado}"
                       Foreground="#2E7D32" FontSize="12"/>
        </Border>

    </Grid>
</Window>
